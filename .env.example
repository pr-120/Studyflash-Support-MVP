# Database (Supabase or local Postgres)
DATABASE_URL="postgresql://postgres:[password]@db.[project].supabase.co:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:[password]@db.[project].supabase.co:5432/postgres"

# Microsoft Graph API (Azure App Registration)
AZURE_CLIENT_ID="your-azure-app-client-id"
AZURE_CLIENT_SECRET="your-azure-app-client-secret"
AZURE_TENANT_ID="your-azure-tenant-id"
SUPPORT_MAILBOX="support@yourcompany.com"

# Anthropic Claude API (optional — enables AI summaries, draft replies, translation fallback)
ANTHROPIC_API_KEY="sk-ant-..."

# LibreTranslate (self-hosted, free, unlimited translation)
# When running via docker compose, this is set automatically.
# For manual setup, point to your LibreTranslate instance.
LIBRETRANSLATE_URL="http://localhost:5000"

# Microsoft Graph webhook validation
GRAPH_WEBHOOK_SECRET="a-random-secret-string"

# NextAuth — required for authentication
# NEXTAUTH_URL must match where you access the app (typically http://localhost:3000)
# NEXTAUTH_SECRET: generate with `openssl rand -base64 32`
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET=""

# ── Optional: Enrichment integrations ──

# Sentry — show recent errors for ticket sender
SENTRY_API_TOKEN=""
SENTRY_ORG=""
SENTRY_PROJECT=""

# PostHog — show recent sessions/recordings for ticket sender
POSTHOG_API_KEY=""
POSTHOG_HOST="https://eu.posthog.com"

# Custom Database — query your own Postgres for user data
# ENRICHMENT_DB_URL is the connection string for your product database.
# ENRICHMENT_DB_QUERY is a SQL query with $1 as the email placeholder.
# Example: SELECT id, name, plan, created_at, last_active FROM users WHERE email = $1
ENRICHMENT_DB_URL=""
ENRICHMENT_DB_QUERY=""
